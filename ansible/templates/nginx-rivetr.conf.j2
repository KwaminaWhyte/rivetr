# /etc/nginx/sites-available/rivetr
# Generated by Ansible — do not edit by hand.
# Proxies all traffic to the Rivetr binary (which handles its own routing).
# For HTTPS, provision a certificate (e.g. certbot) and update the server block.

server {
    listen 80;
    server_name {{ rivetr_domain }} *.{{ rivetr_domain }};

    # Increase timeouts for long-running SSE / WebSocket streams
    proxy_read_timeout 3600s;
    proxy_send_timeout 3600s;

    location / {
        proxy_pass         http://127.0.0.1:{{ rivetr_port }};
        proxy_http_version 1.1;

        # WebSocket support
        proxy_set_header Upgrade    $http_upgrade;
        proxy_set_header Connection "upgrade";

        proxy_set_header Host              $host;
        proxy_set_header X-Real-IP         $remote_addr;
        proxy_set_header X-Forwarded-For   $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
    }
}

