# Rivetr PaaS configuration
# Generated by Ansible — do not edit by hand.

[server]
host = "0.0.0.0"
port = {{ rivetr_port }}
domain = "{{ rivetr_domain }}"
data_dir = "{{ rivetr_data_dir }}"

[auth]
jwt_secret = "{{ rivetr_jwt_secret }}"
admin_email = "{{ rivetr_admin_email }}"
admin_password = "{{ rivetr_admin_password }}"

[proxy]
http_port = {{ rivetr_http_port }}
https_port = {{ rivetr_https_port }}

[runtime]
auto_detect = true
